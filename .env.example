# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=dhl_db
POSTGRES_USER=dhl_user
POSTGRES_PASSWORD=dhl_pass

# ── Application Settings ─────────────────────────────────────
NUM_CLIENTS=10
